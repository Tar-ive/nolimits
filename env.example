# Upstash Redis Configuration
# Get these values from your Upstash Redis dashboard (https://console.upstash.com/)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-rest-token

API_KEY=custom-key

# Google Code Assist OAuth client used to refresh imported Antigravity credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: OpenAI API key — unlocks the `openai` provider (gpt-*/o* models).
# When unset, the gateway routes everything to Anthropic as before.
# OPENAI_API_KEY=sk-...

# Optional: OAuth client ID used only to refresh imported Codex CLI credentials.
# OPENAI_OAUTH_CLIENT_ID=...

# Optional: Cursor session token — unlocks the `cursor` fallback provider.
# Copy the WorkosCursorSessionToken cookie value (form: user_xxx::eyJ...).
# CURSOR_SESSION_TOKEN=user_xxx::eyJ...

# Optional: Anthropic OAuth Client ID
# Defaults to the official Claude CLI ID if not provided
# ANTHROPIC_OAUTH_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e

# Optional: Server port 
# Defaults to 9095 if not provided
# PORT=9095
